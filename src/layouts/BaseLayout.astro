---
import "../styles/global.css";
const { title = "RyluTrails" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-zinc-900">
    <header class="border-b">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
        <a href="/" class="text-xl font-bold">RyluTrails</a>

        <div class="flex gap-4 text-sm">
          <a href="/hikes">Hikes</a>
          <a href="/about">About</a>
        </div>
      </nav>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-8">
      <slot />
    </main>

    <footer class="border-t mt-12">
      <div class="mx-auto max-w-5xl px-4 py-6 text-sm text-zinc-600 flex justify-between items-center">
        <p>© {new Date().getFullYear()} RyLuTrails</p>
        <p>Built by Ryan & Lucas</p>
      </div>
    </footer>

  </body>
</html>