---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const hikes = (await getCollection("hikes")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Hikes | RyluTrails">
  <h1 class="mb-6 text-3xl font-bold">Hikes</h1>

  <div class="grid gap-6 md:grid-cols-2">
    {hikes.map((hike) => (
      <a
        href={`/hikes/${hike.id}`}
        class="block overflow-hidden rounded-xl border transition hover:shadow-md"
      >
        <Image
          src={hike.data.cover}
          alt={hike.data.title}
          class="h-48 w-full object-cover"
          style={`object-position: ${hike.data.coverPosition || "center"}`}
          widths={[500, 900]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="eager"
          fetchpriority="high"
          decoding="sync"
        />

        <div class="p-4">
          <h2 class="text-xl font-semibold">{hike.data.title}</h2>
          <p class="text-sm text-zinc-600">{hike.data.location}</p>
          <p class="text-sm text-zinc-600">
            Overall: {hike.data.ratings.overall}/10
          </p>

          {hike.data.tags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-2">
              {hike.data.tags.map((tag) => (
                <span class="rounded-full border border-zinc-300 bg-zinc-100 px-2 py-1 text-xs font-medium text-zinc-800">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </a>
    ))}
  </div>
</BaseLayout>