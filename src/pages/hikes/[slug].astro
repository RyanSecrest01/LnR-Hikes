---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const hikes = await getCollection("hikes");

  return hikes.map((hike) => ({
    params: { slug: hike.id },
    props: { hike },
  }));
}

const { hike } = Astro.props;
const { Content } = await render(hike);
---

<BaseLayout title={`${hike.data.title} | RyLuTrails`}>
  <article class="space-y-6">
    <div>
      <h1 class="text-4xl font-bold">{hike.data.title}</h1>
      <p class="text-zinc-600">{hike.data.location}</p>
    </div>

    <Image
      src={hike.data.cover}
      alt={hike.data.title}
      class="h-72 w-full rounded-xl object-cover"
      widths={[800, 1200, 1600]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />

    <div class="border-b">
      <div class="flex flex-wrap gap-2">
        <button
          id="tab-overview"
          class="rounded-t-lg border border-b-0 bg-zinc-100 px-4 py-2 text-sm font-medium"
          type="button"
        >
          Overview
        </button>
    
        <button
          id="tab-story"
          class="rounded-t-lg border border-b-0 bg-white px-4 py-2 text-sm font-medium text-zinc-500"
          type="button"
        >
          Story
        </button>
    
        <button
          id="tab-photos"
          class="rounded-t-lg border border-b-0 bg-white px-4 py-2 text-sm font-medium text-zinc-500"
          type="button"
        >
          Photos
        </button>
    
        <button
          id="tab-route"
          class="rounded-t-lg border border-b-0 bg-white px-4 py-2 text-sm font-medium text-zinc-500"
          type="button"
        >
          Route
        </button>
      </div>
    </div>

    <div id="panel-overview" class="space-y-6 pt-6">
      <div class="grid gap-3 rounded-xl border p-4 text-sm md:grid-cols-2">
        <p><strong>Distance:</strong> {hike.data.distanceMiles} miles</p>
        <p><strong>Elevation Gain:</strong> {hike.data.elevationGainFt} ft</p>
        <p><strong>Difficulty:</strong> {hike.data.difficulty}</p>
        <p><strong>Overall:</strong> {hike.data.ratings.overall}/10</p>
      </div>

      <div>
        <a
          href={hike.data.allTrailsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block rounded-lg border px-4 py-2 text-sm font-medium hover:bg-zinc-50"
        >
          View on AllTrails
        </a>
      </div>

      {hike.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {hike.data.tags.map((tag) => (
            <span class="rounded-full bg-zinc-100 px-3 py-1 text-sm text-zinc-700">
              {tag}
            </span>
          ))}
        </div>
      )}

      <section>
        <h2 class="mb-3 text-2xl font-semibold">Ratings</h2>

        <div class="grid gap-3 md:grid-cols-2">
          <div class="rounded-xl border p-4">
            <p class="text-sm text-zinc-500">Trail Quality</p>
            <p class="text-2xl font-bold">{hike.data.ratings.trailQuality}</p>
          </div>

          <div class="rounded-xl border p-4">
            <p class="text-sm text-zinc-500">Views</p>
            <p class="text-2xl font-bold">{hike.data.ratings.views}/10</p>
          </div>

          <div class="rounded-xl border p-4">
            <p class="text-sm text-zinc-500">Crowd</p>
            <p class="text-2xl font-bold">{hike.data.ratings.crowd}</p>
          </div>

          <div class="rounded-xl border p-4">
            <p class="text-sm text-zinc-500">Overall</p>
            <p class="text-2xl font-bold">{hike.data.ratings.overall}/10</p>
          </div>
        </div>
      </section>
    </div>

    <div id="panel-story" class="hidden space-y-6 pt-6">
      <div>
        <h2 class="mb-2 text-2xl font-semibold">Story</h2>
        <div class="prose max-w-none">
          <Content />
        </div>
      </div>
    </div>

    <div id="panel-photos" class="hidden space-y-6 pt-6">
      {hike.data.gallery.length > 0 && (
        <section>
          <h2 class="mb-3 text-2xl font-semibold">Photos</h2>
    
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {hike.data.gallery.map((img, index) => (
              <Image
                src={img}
                alt={hike.data.title}
                class="gallery-image h-56 w-full cursor-pointer rounded-xl object-cover transition hover:scale-[1.02]"
                widths={[500, 900, 1400]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                data-full={img.src}
                data-index={index}
              />
            ))}
          </div>
        </section>
      )}
    </div>

    <div id="panel-route" class="hidden space-y-6 pt-6">
      <section>
        <h2 class="mb-3 text-2xl font-semibold">Route</h2>
        <p class="text-zinc-700">
          Route map, GPX data, and elevation profile will go here.
        </p>
      </section>
    </div>

    <div
      id="image-modal"
      class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-4"
    >
      <button
        id="close-modal"
        class="absolute right-4 top-4 flex h-10 w-10 items-center justify-center rounded-full bg-white/20 text-xl text-white backdrop-blur transition hover:bg-white/40 hover:scale-110 active:scale-95 active:bg-white/60"
        type="button"
      >
        ×
      </button>

      <button
        id="prev-image"
        class="absolute left-4 top-1/2 -translate-y-1/2 flex h-12 w-12 items-center justify-center rounded-full bg-white/20 text-2xl text-white backdrop-blur transition hover:bg-white/40 hover:scale-110 active:scale-95 active:bg-white/60"
        type="button"
      >
        <span class="relative -top-[1px]">‹</span>
      </button>

      <img
        id="modal-image"
        src=""
        alt="Expanded hike photo"
        class="max-h-[90vh] max-w-[90vw] rounded-xl object-contain"
      />

      <button
        id="next-image"
        class="absolute right-4 top-1/2 -translate-y-1/2 flex h-12 w-12 items-center justify-center rounded-full bg-white/20 text-2xl text-white backdrop-blur transition hover:bg-white/40 hover:scale-110 active:scale-95 active:bg-white/60"
        type="button"
      >
        <span class="relative -top-[1px]">›</span>
      </button>
    </div>
  </article>

  <script define:vars={{ gallery: hike.data.gallery.map((img) => img.src) }}>
    const modal = document.getElementById("image-modal");
    const modalImage = document.getElementById("modal-image");
    const galleryImages = document.querySelectorAll(".gallery-image");
    const prevButton = document.getElementById("prev-image");
    const nextButton = document.getElementById("next-image");
    const closeButton = document.getElementById("close-modal");

    const overviewTab = document.getElementById("tab-overview");
    const storyTab = document.getElementById("tab-story");
    const overviewPanel = document.getElementById("panel-overview");
    const storyPanel = document.getElementById("panel-story");
    const photosTab = document.getElementById("tab-photos");
    const routeTab = document.getElementById("tab-route");
    const photosPanel = document.getElementById("panel-photos");
    const routePanel = document.getElementById("panel-route");

    let currentIndex = 0;

    function openModal(index) {
      if (!modal || !modalImage) return;
      currentIndex = index;
      modalImage.setAttribute("src", gallery[currentIndex]);
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    }

    function closeModal() {
      if (!modal || !modalImage) return;
      modal.classList.remove("flex");
      modal.classList.add("hidden");
      modalImage.setAttribute("src", "");
    }

    function showNext() {
      currentIndex = (currentIndex + 1) % gallery.length;
      modalImage?.setAttribute("src", gallery[currentIndex]);
    }

    function showPrev() {
      currentIndex = (currentIndex - 1 + gallery.length) % gallery.length;
      modalImage?.setAttribute("src", gallery[currentIndex]);
    }

    function activateTab(activeTab, activePanel) {
      const tabs = [overviewTab, storyTab, photosTab, routeTab];
      const panels = [overviewPanel, storyPanel, photosPanel, routePanel];

      panels.forEach((panel) => panel?.classList.add("hidden"));
      activePanel?.classList.remove("hidden");

      tabs.forEach((tab) => {
        tab?.classList.remove("bg-zinc-100");
        tab?.classList.add("bg-white", "text-zinc-500");
      });

      activeTab?.classList.add("bg-zinc-100");
      activeTab?.classList.remove("bg-white", "text-zinc-500");
    }

    overviewTab?.addEventListener("click", () => {
      activateTab(overviewTab, overviewPanel);
    });

    storyTab?.addEventListener("click", () => {
      activateTab(storyTab, storyPanel);
    });

    photosTab?.addEventListener("click", () => {
      activateTab(photosTab, photosPanel);
    });

    routeTab?.addEventListener("click", () => {
      activateTab(routeTab, routePanel);
    });

    galleryImages.forEach((img) => {
      img.addEventListener("click", () => {
        const index = Number(img.getAttribute("data-index"));
        openModal(index);
      });
    });

    nextButton?.addEventListener("click", (e) => {
      e.stopPropagation();
      showNext();
    });

    prevButton?.addEventListener("click", (e) => {
      e.stopPropagation();
      showPrev();
    });

    closeButton?.addEventListener("click", (e) => {
      e.stopPropagation();
      closeModal();
    });

    modal?.addEventListener("click", () => {
      closeModal();
    });

    document.addEventListener("keydown", (e) => {
      if (modal?.classList.contains("hidden")) return;

      if (e.key === "Escape") closeModal();
      if (e.key === "ArrowRight") showNext();
      if (e.key === "ArrowLeft") showPrev();
    });
  </script>
</BaseLayout>