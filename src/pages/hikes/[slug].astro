---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const hikes = await getCollection("hikes");

  return hikes.map((hike) => ({
    params: { slug: hike.id },
    props: { hike },
  }));
}

const { hike } = Astro.props;
const { Content } = await render(hike);
---

<BaseLayout title={`${hike.data.title} | RyLuTrails`}>
  <article class="space-y-6">
    <div>
      <h1 class="text-4xl font-bold">{hike.data.title}</h1>
      <p class="text-zinc-600">{hike.data.location}</p>
    </div>

    <img
      src={hike.data.cover}
      alt={hike.data.title}
      class="h-72 w-full rounded-xl object-cover"
    />

    <div class="grid gap-3 rounded-xl border p-4 text-sm md:grid-cols-2">
      <p><strong>Distance:</strong> {hike.data.distanceMiles} miles</p>
      <p><strong>Elevation Gain:</strong> {hike.data.elevationGainFt} ft</p>
      <p><strong>Difficulty:</strong> {hike.data.difficulty}</p>
      <p><strong>Overall:</strong> {hike.data.ratings.overall}/10</p>
    </div>

    <div>
      <h2 class="mb-2 text-2xl font-semibold">Review</h2>
      <div class="prose max-w-none">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>