---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const hikes = await getCollection("hikes");

  return hikes.map((hike) => ({
    params: { slug: hike.id },
    props: { hike },
  }));
}

const { hike } = Astro.props;
const { Content } = await render(hike);
---

<BaseLayout title={`${hike.data.title} | RyLuTrails`}>
  <article class="space-y-6">
    <div>
      <h1 class="text-4xl font-bold">{hike.data.title}</h1>
      <p class="text-zinc-600">{hike.data.location}</p>
    </div>

    <img
      src={hike.data.cover}
      alt={hike.data.title}
      class="h-72 w-full rounded-xl object-cover"
    />

    <div class="grid gap-3 rounded-xl border p-4 text-sm md:grid-cols-2">
      <p><strong>Distance:</strong> {hike.data.distanceMiles} miles</p>
      <p><strong>Elevation Gain:</strong> {hike.data.elevationGainFt} ft</p>
      <p><strong>Difficulty:</strong> {hike.data.difficulty}</p>
      <p><strong>Overall:</strong> {hike.data.ratings.overall}/10</p>
    </div>

    <div>
        <a
            href={hike.data.allTrailsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block rounded-lg border px-4 py-2 text-sm font-medium hover:bg-zinc-50"
        >
            View on AllTrails
        </a>
    </div>

    {hike.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
            {hike.data.tags.map((tag) => (
            <span class="rounded-full bg-zinc-100 px-3 py-1 text-sm text-zinc-700">
                {tag}
            </span>
            ))}
        </div>
    )}

    <section>
        <h2 class="mb-3 text-2xl font-semibold">Ratings</h2>

        <div class="grid gap-3 md:grid-cols-2">
            <div class="rounded-xl border p-4">
            <p class="text-sm text-zinc-500">Trail Quality</p>
            <p class="text-2xl font-bold">{hike.data.ratings.trailQuality}</p>
            </div>

            <div class="rounded-xl border p-4">
            <p class="text-sm text-zinc-500">Views</p>
            <p class="text-2xl font-bold">{hike.data.ratings.views}/10</p>
            </div>

            <div class="rounded-xl border p-4">
            <p class="text-sm text-zinc-500">Crowd</p>
            <p class="text-2xl font-bold">{hike.data.ratings.crowd}</p>
            </div>

            <div class="rounded-xl border p-4">
            <p class="text-sm text-zinc-500">Overall</p>
            <p class="text-2xl font-bold">{hike.data.ratings.overall}/10</p>
            </div>
        </div>
    </section>

    {hike.data.gallery.length > 0 && (
        <section>
            <h2 class="mb-3 text-2xl font-semibold">Photos</h2>

            <div class="grid gap-3 md:grid-cols-2">
            {hike.data.gallery.map((img) => (
                <img
                src={img}
                alt={hike.data.title}
                class="h-64 w-full rounded-xl object-cover"
                />
            ))}
            </div>
        </section>
    )}

    <div>
      <h2 class="mb-2 text-2xl font-semibold">Review</h2>
      <div class="prose max-w-none">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>