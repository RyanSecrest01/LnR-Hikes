---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Changelog | RyLuTrails">
  <div class="space-y-6">
    <h1 class="text-3xl font-bold">Changelog</h1>

    <p class="text-zinc-700">
      Updates and improvements to the site over time.
    </p>

    <div class="rounded-xl border p-4">
      <p class="text-sm text-zinc-500">2026-04-03</p>
      <h2 class="text-xl font-semibold">Initial Site Build</h2>

      <ul class="mt-2 list-disc pl-5 text-zinc-700">
        <li>Created hiking site structure</li>
        <li>Added hike pages with ratings</li>
        <li>Added photo gallery with modal view</li>
        <li>Styled layout and navigation</li>
      </ul>
    </div>
  </div>
</BaseLayout>