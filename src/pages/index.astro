---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import heroImage from "../assets/hikes/central-peak/4.avif";

const hikes = await getCollection("hikes");

const latestHikes = [...hikes]
  .sort(
    (a, b) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  )
  .slice(0, 2);
---

<BaseLayout title="RyLuTrails">
  <section class="space-y-4">
    <h1 class="text-4xl font-bold">RyLuTrails</h1>
    <p class="text-lg text-zinc-700">
      Hikes, photos, and ratings from Ryan and Lucas.
    </p>
  </section>

  <div class="mt-6 overflow-hidden rounded-2xl border">
    <Image
      src={heroImage}
      alt="RyluTrails featured hike"
      class="h-72 w-full object-cover"
      widths={[800, 1200, 1600]}
      sizes="(max-width: 768px) 100vw, 1200px"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <section class="mt-10">
    <h2 class="mb-4 text-2xl font-semibold">Latest Hikes</h2>

    <div class="grid gap-6 md:grid-cols-2">
      {latestHikes.map((hike) => (
        <a
          href={`/hikes/${hike.id}`}
          class="block overflow-hidden rounded-xl border transition hover:shadow-md"
        >
          <Image
            src={hike.data.cover}
            alt={hike.data.title}
            class="h-48 w-full object-cover"
            widths={[500, 900]}
            sizes="(max-width: 768px) 100vw, 50vw"
            loading="eager"
            fetchpriority="high"
          />

          <div class="p-4">
            <h3 class="text-xl font-semibold">{hike.data.title}</h3>
            <p class="text-sm text-zinc-600">{hike.data.location}</p>
            <p class="text-sm text-zinc-600">
              Overall: {hike.data.ratings.overall}/10
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>